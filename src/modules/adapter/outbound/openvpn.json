{
  "type": "object",
  "title": "outbound-openvpn",
  "definitions": {
    "compatible": { "$ref": "../../../definitions/compatible.json" },
    "types": { "$ref": "../../../definitions/types.json" },
    "patterns": { "$ref": "../../../definitions/patterns.json" },
    "enums": { "$ref": "../../../definitions/enums.json" },
    "data-cipher": {
      "enum": [
        "AES-128-GCM",
        "AES-192-GCM",
        "AES-256-GCM",
        "AES-CBC",
        "AES-128-CBC",
        "AES-192-CBC",
        "AES-256-CBC",
        "CHACHA20-POLY1305"
      ]
    },
    "non-whitespace-value": {
      "anyOf": [{ "type": "string", "pattern": "\\S" }, { "not": { "type": "string" } }]
    },
    "tls-auth-mode": {
      "required": ["tls-auth"],
      "properties": { "tls-auth": { "$ref": "#/definitions/non-whitespace-value" } }
    },
    "tls-crypt-mode": {
      "required": ["tls-crypt"],
      "properties": { "tls-crypt": { "$ref": "#/definitions/non-whitespace-value" } }
    },
    "tls-crypt-v2-mode": {
      "required": ["tls-crypt-v2"],
      "properties": { "tls-crypt-v2": { "$ref": "#/definitions/non-whitespace-value" } }
    },
    "basic-option": { "$ref": "./base.json#/definitions/basic-option" },
    "smux": { "$ref": "./singmux.json" }
  },
  "allOf": [
    { "title": "basic配置", "$ref": "#/definitions/basic-option" },
    {
      "type": "object",
      "title": "openvpn配置",
      "required": ["name", "server", "port", "ca"],
      "properties": {
        "type": {
          "$ref": "#/definitions/compatible/string",
          "title": "代理节点类型",
          "description": "代理节点类型",
          "markdownDescription": "代理节点类型"
        },
        "name": {
          "$ref": "#/definitions/compatible/string",
          "title": "代理节点名称",
          "description": "代理节点名称",
          "markdownDescription": "代理节点名称"
        },
        "server": {
          "$ref": "#/definitions/patterns/server",
          "title": "代理节点服务器",
          "description": "域名或IP",
          "markdownDescription": "域名或IP"
        },
        "port": {
          "$ref": "#/definitions/patterns/port",
          "title": "代理节点端口号",
          "description": "代理节点端口号",
          "markdownDescription": "代理节点端口号"
        },
        "proto": {
          "enum": ["udp", "udp4", "tcp", "tcp-client", "tcp4", "tcp4-client"],
          "title": "传输协议",
          "description": "传输协议",
          "markdownDescription": "传输协议",
          "default": "udp"
        },
        "dev": {
          "enum": ["tun"],
          "title": "设备类型",
          "description": "设备类型",
          "markdownDescription": "设备类型",
          "default": "tun"
        },
        "cipher": {
          "$ref": "#/definitions/data-cipher",
          "title": "加密方式",
          "description": "加密方式",
          "markdownDescription": "加密方式",
          "default": "AES-128-GCM"
        },
        "data-ciphers": {
          "type": "array",
          "items": { "$ref": "#/definitions/compatible/string" },
          "title": "数据通道加密协商列表",
          "description": "向服务端通告的数据通道加密方式列表，按服务端列表顺序选择首个双方支持的值",
          "markdownDescription": "向服务端通告的数据通道加密方式列表，按服务端列表顺序选择首个双方支持的值"
        },
        "data-ciphers-fallback": {
          "$ref": "#/definitions/compatible/string",
          "title": "数据通道回退加密方式",
          "description": "协商无共同加密方式时使用的回退加密方式",
          "markdownDescription": "协商无共同加密方式时使用的回退加密方式"
        },
        "auth": {
          "enum": ["MD5", "SHA1", "SHA256", "SHA384", "SHA512"],
          "title": "认证方式",
          "description": "AEAD cipher 会忽略 auth",
          "markdownDescription": "AEAD cipher 会忽略 auth",
          "default": "SHA256"
        },
        "comp-lzo": {
          "enum": ["yes", "no", "adaptive"],
          "markdownEnumDescriptions": ["启用", "禁用", "自动"],
          "title": "LZO压缩",
          "description": "Lempel-Ziv-Oberhumer 压缩策略",
          "markdownDescription": "Lempel-Ziv-Oberhumer 压缩策略",
          "default": "no"
        },
        "ca": {
          "$ref": "#/definitions/compatible/string",
          "title": "CA证书内容",
          "description": "从 .ovpn 中复制 \\<ca>\\</ca> 内的内容，不需要保留 \\<ca> 标签",
          "markdownDescription": "从 `.ovpn` 中复制 `<ca></ca>` 内的内容，不需要保留 `<ca>` 标签"
        },
        "cert": {
          "$ref": "#/definitions/compatible/string",
          "title": "证书内容",
          "description": "从 .ovpn 中复制 \\<cert>\\</cert> 内的内容（auth-user-pass 时可省略 cert / key）",
          "markdownDescription": "从 `.ovpn` 中复制 `<cert></cert>` 内的内容（auth-user-pass 时可省略 cert / key）"
        },
        "key": {
          "$ref": "#/definitions/compatible/string",
          "title": "私钥内容",
          "description": "从 .ovpn 中复制 \\<key>\\</key> 内的内容",
          "markdownDescription": "从 `.ovpn` 中复制 `<key></key>` 内的内容"
        },
        "tls-auth": {
          "$ref": "#/definitions/compatible/string",
          "title": "TLS-Auth 静态密钥内容",
          "description": "从 .ovpn 中复制 \\<tls-auth>\\</tls-auth> 内的内容，不需要保留标签；与 tls-crypt、tls-crypt-v2 互斥",
          "markdownDescription": "从 `.ovpn` 中复制 `<tls-auth></tls-auth>` 内的内容，不需要保留标签；与 `tls-crypt`、`tls-crypt-v2` 互斥"
        },
        "key-direction": {
          "enum": ["1", "0", ""],
          "markdownEnumDescriptions": ["单向模式（方向 1）", "单向模式（方向 0）", "双向模式"],
          "title": "TLS-Auth 密钥方向",
          "description": "仅用于 tls-auth；留空为双向模式",
          "markdownDescription": "仅用于 `tls-auth`；留空为双向模式"
        },
        "tls-crypt": {
          "$ref": "#/definitions/compatible/string",
          "title": "静态密钥内容",
          "description": "从 .ovpn 中复制 \\<tls-crypt>\\</tls-crypt> 内的内容，不需要保留 \\<tls-crypt> 标签；与 tls-auth、tls-crypt-v2 互斥",
          "markdownDescription": "从 `.ovpn` 中复制 `<tls-crypt></tls-crypt>` 内的内容，不需要保留 `<tls-crypt>` 标签；与 `tls-auth`、`tls-crypt-v2` 互斥"
        },
        "tls-crypt-v2": {
          "$ref": "#/definitions/compatible/string",
          "title": "TLS-Crypt-v2 客户端密钥内容",
          "description": "从 .ovpn 中复制 \\<tls-crypt-v2>\\</tls-crypt-v2> 内包含 PEM 标签的客户端密钥内容；与 tls-auth、tls-crypt 互斥",
          "markdownDescription": "从 `.ovpn` 中复制 `<tls-crypt-v2></tls-crypt-v2>` 内包含 PEM 标签的客户端密钥内容；与 `tls-auth`、`tls-crypt` 互斥"
        },
        "username": {
          "$ref": "#/definitions/compatible/string",
          "title": "用户名",
          "description": "认证用户名",
          "markdownDescription": "认证用户名"
        },
        "password": {
          "$ref": "#/definitions/compatible/string",
          "title": "密码",
          "description": "认证密码",
          "markdownDescription": "认证密码"
        },
        "peer-info": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/compatible/string" },
          "title": "对端信息",
          "description": "透传给服务端的 peer-info 键值对，追加在内置 peer-info 之后",
          "markdownDescription": "透传给服务端的 `peer-info` 键值对，追加在内置 `peer-info` 之后"
        },
        "ping": {
          "$ref": "#/definitions/compatible/integer",
          "title": "每隔多长时间发送一次保活包",
          "description": "单位:s",
          "markdownDescription": "单位:s",
          "default": 0
        },
        "ping-restart": {
          "$ref": "#/definitions/compatible/integer",
          "title": "多长时间内没有响应就判定超时并重连",
          "description": "单位:s",
          "markdownDescription": "单位:s",
          "default": 0
        },
        "handshake-timeout": {
          "$ref": "#/definitions/compatible/integer",
          "title": "握手超时时间",
          "description": "单位:s，0不设置额外握手超时，受外层上下文控制",
          "markdownDescription": "单位:`s`，`0`不设置额外握手超时，受外层上下文控制",
          "default": 0
        },
        "mtu": {
          "$ref": "#/definitions/compatible/integer",
          "title": "最大传输单元",
          "description": "最大传输单元",
          "markdownDescription": "最大传输单元",
          "default": 1500
        },
        "udp": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "启用UDP",
          "description": "启用UDP",
          "markdownDescription": "启用`UDP`",
          "default": true
        },
        "remote-dns-resolve": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "强制DNS远程解析",
          "description": "强制DNS远程解析",
          "markdownDescription": "强制DNS远程解析",
          "default": false
        },
        "dns": {
          "$ref": "#/definitions/types/stringArray",
          "title": "DNS服务器列表",
          "description": "仅在 remote-dns-resolve 为 true 时生效",
          "markdownDescription": "仅在 `remote-dns-resolve` 为 `true` 时生效"
        }
      },
      "allOf": [
        { "if": { "required": ["cert"] }, "then": { "required": ["cert", "key"] } },
        { "if": { "required": ["key"] }, "then": { "required": ["cert", "key"] } },
        {
          "not": {
            "anyOf": [
              {
                "allOf": [
                  { "$ref": "#/definitions/tls-auth-mode" },
                  { "$ref": "#/definitions/tls-crypt-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/tls-auth-mode" },
                  { "$ref": "#/definitions/tls-crypt-v2-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/tls-crypt-mode" },
                  { "$ref": "#/definitions/tls-crypt-v2-mode" }
                ]
              }
            ]
          }
        },
        { "if": { "not": { "required": ["cert", "key"] } }, "then": { "required": ["username"] } }
      ]
    },
    {
      "type": "object",
      "title": "smux配置",
      "properties": { "smux": { "title": "smux配置", "$ref": "#/definitions/smux" } }
    }
  ]
}
