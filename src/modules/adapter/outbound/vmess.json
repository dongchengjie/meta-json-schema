{
  "type": "object",
  "title": "outbound-vmess",
  "definitions": {
    "compatible": { "$ref": "../../../definitions/compatible.json" },
    "types": { "$ref": "../../../definitions/types.json" },
    "patterns": { "$ref": "../../../definitions/patterns.json" },
    "enums": { "$ref": "../../../definitions/enums.json" },
    "basic-option": { "$ref": "./base.json#/definitions/basic-option" },
    "ech-options": { "$ref": "./ech.json#/definitions/ech-options" },
    "smux": { "$ref": "./singmux.json" },
    "reality-option": { "$ref": "./reality.json" },
    "tlsmirror-time-spec": {
      "type": "object",
      "title": "TLSMirror 延迟配置",
      "properties": {
        "base-nanoseconds": {
          "$ref": "#/definitions/compatible/integer",
          "title": "固定延迟",
          "description": "单位:ns",
          "markdownDescription": "单位:`ns`",
          "default": 0
        },
        "uniform-random-multiplier-nanoseconds": {
          "$ref": "#/definitions/compatible/integer",
          "title": "随机延迟上限",
          "description": "单位:ns",
          "markdownDescription": "单位:`ns`",
          "default": 0
        }
      }
    },
    "tlsmirror-connection-enrolment": {
      "type": "object",
      "title": "TLSMirror 连接登记配置",
      "properties": {
        "primary-ingress-outbound": {
          "$ref": "#/definitions/compatible/string",
          "title": "主入站控制出站",
          "description": "连接登记使用的主入站控制出站",
          "markdownDescription": "连接登记使用的主入站控制出站"
        },
        "primary-egress-outbound": {
          "$ref": "#/definitions/compatible/string",
          "title": "主出站控制出站",
          "description": "连接登记使用的主出站控制出站",
          "markdownDescription": "连接登记使用的主出站控制出站"
        }
      }
    },
    "tlsmirror-traffic-header": {
      "type": "object",
      "title": "TLSMirror HTTP 请求头",
      "properties": {
        "name": {
          "$ref": "#/definitions/compatible/string",
          "title": "请求头名称",
          "description": "HTTP请求头名称",
          "markdownDescription": "`HTTP`请求头名称"
        },
        "value": {
          "$ref": "#/definitions/compatible/string",
          "title": "请求头值",
          "description": "HTTP请求头值",
          "markdownDescription": "`HTTP`请求头值"
        },
        "values": {
          "$ref": "#/definitions/types/stringArray",
          "title": "请求头值列表",
          "description": "HTTP请求头值列表",
          "markdownDescription": "`HTTP`请求头值列表"
        }
      }
    },
    "tlsmirror-next-step": {
      "type": "object",
      "title": "TLSMirror 后续步骤候选",
      "properties": {
        "weight": {
          "$ref": "#/definitions/compatible/integer",
          "title": "候选权重",
          "description": "后续步骤候选权重",
          "markdownDescription": "后续步骤候选权重"
        },
        "goto-location": {
          "$ref": "#/definitions/compatible/integer",
          "title": "目标步骤索引",
          "description": "目标步骤索引",
          "markdownDescription": "目标步骤索引"
        }
      }
    },
    "tlsmirror-traffic-step": {
      "type": "object",
      "title": "TLSMirror HTTP 流量步骤",
      "properties": {
        "name": {
          "$ref": "#/definitions/compatible/string",
          "title": "步骤名称",
          "description": "流量步骤名称",
          "markdownDescription": "流量步骤名称"
        },
        "host": {
          "$ref": "#/definitions/compatible/string",
          "title": "HTTP主机",
          "description": "HTTP请求主机",
          "markdownDescription": "`HTTP`请求主机"
        },
        "path": {
          "$ref": "#/definitions/compatible/string",
          "title": "HTTP路径",
          "description": "HTTP请求路径",
          "markdownDescription": "`HTTP`请求路径"
        },
        "method": {
          "$ref": "#/definitions/compatible/string",
          "title": "HTTP方法",
          "description": "HTTP请求方法",
          "markdownDescription": "`HTTP`请求方法"
        },
        "headers": {
          "type": "array",
          "title": "HTTP 请求头列表",
          "description": "HTTP请求头列表",
          "markdownDescription": "`HTTP`请求头列表",
          "items": { "$ref": "#/definitions/tlsmirror-traffic-header" }
        },
        "next-step": {
          "type": "array",
          "title": "后续步骤候选列表",
          "description": "后续步骤候选列表",
          "markdownDescription": "后续步骤候选列表",
          "items": { "$ref": "#/definitions/tlsmirror-next-step" }
        },
        "connection-ready": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "连接就绪标记",
          "description": "此步骤完成后交付代理连接",
          "markdownDescription": "此步骤完成后交付代理连接",
          "default": false
        },
        "connection-recall-exit": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "连接回收后退出",
          "description": "代理连接关闭后退出载体流量",
          "markdownDescription": "代理连接关闭后退出载体流量",
          "default": false
        },
        "wait-time": {
          "$ref": "#/definitions/tlsmirror-time-spec",
          "title": "等待时间",
          "description": "步骤完成后的等待时间",
          "markdownDescription": "步骤完成后的等待时间"
        },
        "h2-do-not-wait-for-download-finish": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "HTTP/2 不等待响应体读取完成",
          "description": "HTTP/2下不等待响应体读取完成",
          "markdownDescription": "`HTTP/2`下不等待响应体读取完成",
          "default": false
        }
      }
    },
    "tlsmirror-option": {
      "type": "object",
      "title": "TLSMirror 配置",
      "required": ["primary-key"],
      "properties": {
        "primary-key": {
          "$ref": "#/definitions/compatible/string",
          "title": "TLSMirror 主密钥",
          "description": "标准 Base64 编码的 32 字节主密钥",
          "markdownDescription": "标准 Base64 编码的 32 字节主密钥"
        },
        "explicit-nonce-ciphersuites": {
          "type": "array",
          "title": "TLS 1.2 显式 nonce 加密套件",
          "description": "TLS 1.2载体使用显式nonce的加密套件",
          "markdownDescription": "`TLS 1.2`载体使用显式`nonce`的加密套件",
          "items": { "$ref": "#/definitions/compatible/integer" }
        },
        "defer-instance-derived-write-time": {
          "$ref": "#/definitions/tlsmirror-time-spec",
          "title": "首次写入延迟",
          "description": "首次写入前的延迟",
          "markdownDescription": "首次写入前的延迟"
        },
        "transport-layer-padding": {
          "type": "object",
          "title": "传输层填充配置",
          "description": "传输层填充配置",
          "markdownDescription": "传输层填充配置",
          "properties": {
            "enabled": {
              "$ref": "#/definitions/compatible/boolean",
              "title": "启用传输层填充",
              "description": "启用传输层填充",
              "markdownDescription": "启用传输层填充",
              "default": false
            }
          }
        },
        "connection-enrolment": {
          "$ref": "#/definitions/tlsmirror-connection-enrolment",
          "title": "连接登记配置",
          "description": "启用兼容V2Ray的连接登记确认",
          "markdownDescription": "启用兼容`V2Ray`的连接登记确认"
        },
        "embedded-traffic-generator": {
          "type": "object",
          "title": "内嵌 HTTP 流量生成器",
          "description": "生成额外的HTTP载体流量",
          "markdownDescription": "生成额外的`HTTP`载体流量",
          "properties": {
            "steps": {
              "type": "array",
              "title": "流量步骤列表",
              "description": "HTTP载体流量步骤列表",
              "markdownDescription": "`HTTP`载体流量步骤列表",
              "items": { "$ref": "#/definitions/tlsmirror-traffic-step" }
            }
          }
        },
        "sequence-watermarking-enabled": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "启用序列水印",
          "description": "启用序列水印",
          "markdownDescription": "启用序列水印",
          "default": false
        }
      }
    },
    "mkcp-option": {
      "type": "object",
      "title": "mKCP 配置",
      "properties": {
        "mtu": {
          "$ref": "#/definitions/compatible/integer",
          "title": "最大传输单元",
          "description": "最大传输单元",
          "markdownDescription": "最大传输单元",
          "default": 1350
        },
        "tti": {
          "$ref": "#/definitions/compatible/integer",
          "title": "传输时间间隔",
          "description": "单位:ms，0 使用默认值 50",
          "markdownDescription": "单位:`ms`，0 使用默认值 50",
          "default": 50
        },
        "uplink-capacity": {
          "$ref": "#/definitions/compatible/integer",
          "title": "上行容量",
          "description": "单位:MB/s",
          "markdownDescription": "单位:`MB/s`",
          "default": 5
        },
        "downlink-capacity": {
          "$ref": "#/definitions/compatible/integer",
          "title": "下行容量",
          "description": "单位:MB/s",
          "markdownDescription": "单位:`MB/s`",
          "default": 20
        },
        "congestion": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "启用拥塞控制",
          "description": "启用拥塞控制",
          "markdownDescription": "启用拥塞控制",
          "default": false
        },
        "write-buffer": {
          "$ref": "#/definitions/compatible/integer",
          "title": "写缓冲区大小",
          "description": "单位:bytes",
          "markdownDescription": "单位:`bytes`",
          "default": 2097152
        },
        "read-buffer": {
          "$ref": "#/definitions/compatible/integer",
          "title": "读缓冲区大小",
          "description": "单位:bytes",
          "markdownDescription": "单位:`bytes`",
          "default": 2097152
        },
        "seed": {
          "$ref": "#/definitions/compatible/string",
          "title": "AES-GCM 认证种子",
          "description": "留空使用默认认证",
          "markdownDescription": "留空使用默认认证",
          "default": ""
        },
        "header": {
          "enum": [
            "",
            "none",
            "noop",
            "srtp",
            "utp",
            "wechat-video",
            "wechat",
            "dtls",
            "wireguard"
          ],
          "title": "伪装包头",
          "description": "伪装包头",
          "markdownDescription": "伪装包头",
          "default": ""
        }
      }
    },
    "http-option": {
      "type": "object",
      "title": "HTTP配置",
      "properties": {
        "method": {
          "$ref": "#/definitions/compatible/string",
          "title": "请求方式",
          "description": "请求方式",
          "markdownDescription": "请求方式",
          "default": "GET"
        },
        "path": {
          "$ref": "#/definitions/types/stringArray",
          "title": "路径",
          "description": "路径",
          "markdownDescription": "路径",
          "default": ["/"]
        },
        "headers": {
          "type": "object",
          "title": "请求头",
          "description": "请求头",
          "markdownDescription": "请求头"
        }
      }
    },
    "http2-option": {
      "type": "object",
      "title": "HTTP2配置",
      "properties": {
        "host": {
          "$ref": "#/definitions/types/stringArray",
          "title": "主机地址",
          "description": "主机地址",
          "markdownDescription": "主机地址",
          "default": ["www.example.com"]
        },
        "path": {
          "$ref": "#/definitions/compatible/string",
          "title": "路径",
          "description": "路径",
          "markdownDescription": "路径",
          "default": "/"
        }
      }
    },
    "grpc-option": {
      "type": "object",
      "title": "GRPC配置",
      "properties": {
        "grpc-service-name": {
          "$ref": "#/definitions/compatible/string",
          "title": "GRPC服务名称",
          "description": "GRPC服务名称",
          "markdownDescription": "GRPC服务名称"
        },
        "grpc-user-agent": {
          "$ref": "#/definitions/compatible/string",
          "title": "GRPC用户代理",
          "description": "GRPC用户代理",
          "markdownDescription": "GRPC用户代理"
        },
        "ping-interval": {
          "$ref": "#/definitions/compatible/integer",
          "title": "GRPC心跳间隔",
          "description": "单位:s",
          "markdownDescription": "单位:s"
        },
        "max-connections": {
          "$ref": "#/definitions/compatible/integer",
          "title": "最大连接数",
          "description": "与 max-streams 冲突",
          "markdownDescription": "与 `max-streams` 冲突"
        },
        "min-streams": {
          "$ref": "#/definitions/compatible/integer",
          "title": "每连接最小复用流数",
          "description": "与 max-streams 冲突",
          "markdownDescription": "与 `max-streams` 冲突"
        },
        "max-streams": {
          "$ref": "#/definitions/compatible/integer",
          "title": "每连接最大复用流数",
          "description": "与 max-connections 、 min-streams 冲突",
          "markdownDescription": "与 `max-connections` 、 `min-streams` 冲突"
        }
      },
      "allOf": [
        {
          "if": { "required": ["max-connections", "max-streams"] },
          "then": { "deprecationMessage": "max-connections 与 max-streams 不能同时设置" }
        },
        {
          "if": { "required": ["min-streams", "max-streams"] },
          "then": { "deprecationMessage": "min-streams 与 max-streams 不能同时设置" }
        }
      ]
    },
    "ws-option": {
      "type": "object",
      "title": "WS配置",
      "properties": {
        "path": {
          "$ref": "#/definitions/compatible/string",
          "title": "路径",
          "description": "路径",
          "markdownDescription": "路径",
          "default": "/"
        },
        "headers": {
          "type": "object",
          "title": "请求头",
          "description": "请求头",
          "markdownDescription": "请求头"
        },
        "max-early-data": {
          "$ref": "#/definitions/compatible/integer",
          "title": "最大早期数据大小",
          "description": "单位:bytes",
          "markdownDescription": "单位:`bytes`"
        },
        "early-data-header-name": {
          "$ref": "#/definitions/compatible/string",
          "title": "早期数据使用的header字段名",
          "description": "早期数据使用的header字段名",
          "markdownDescription": "早期数据使用的header字段名"
        },
        "v2ray-http-upgrade": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "启用HTTP协议升级",
          "description": "通过HTTP协议与客户端进行通信,并在需要时升级到更高级的协议",
          "markdownDescription": "通过HTTP协议与客户端进行通信,并在需要时升级到更高级的协议"
        },
        "v2ray-http-upgrade-fast-open": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "启用TFO(TCP Fast Open)",
          "description": "启用TFO(TCP Fast Open)",
          "markdownDescription": "启用`TFO`(TCP Fast Open)"
        }
      }
    }
  },
  "allOf": [
    { "title": "basic配置", "$ref": "#/definitions/basic-option" },
    {
      "type": "object",
      "title": "vmess配置",
      "required": ["name", "server", "port", "uuid", "alterId", "cipher"],
      "properties": {
        "type": {
          "$ref": "#/definitions/compatible/string",
          "title": "代理节点类型",
          "description": "代理节点类型",
          "markdownDescription": "代理节点类型"
        },
        "name": {
          "$ref": "#/definitions/compatible/string",
          "title": "代理节点名称",
          "description": "代理节点名称",
          "markdownDescription": "代理节点名称"
        },
        "server": {
          "$ref": "#/definitions/patterns/server",
          "title": "代理节点服务器",
          "description": "域名或IP",
          "markdownDescription": "域名或IP"
        },
        "port": {
          "$ref": "#/definitions/patterns/port",
          "title": "代理节点端口号",
          "description": "代理节点端口号",
          "markdownDescription": "代理节点端口号"
        },
        "uuid": {
          "$ref": "#/definitions/patterns/uuid",
          "title": "UUID",
          "description": "UUID",
          "markdownDescription": "UUID"
        },
        "alterId": {
          "$ref": "#/definitions/compatible/integer",
          "title": "AlterID",
          "description": "Alternate ID(替代标识)",
          "markdownDescription": "Alternate ID(替代标识)"
        },
        "cipher": {
          "$ref": "#/definitions/enums/cipher",
          "title": "加密方法",
          "description": "加密方法",
          "markdownDescription": "加密方法"
        },
        "udp": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "启用UDP",
          "description": "启用UDP",
          "markdownDescription": "启用`UDP`"
        },
        "network": {
          "enum": ["tcp", "ws", "http", "h2", "grpc", "mkcp", "kcp"],
          "title": "传输协议",
          "description": "传输协议",
          "markdownDescription": "传输协议"
        },
        "tls": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "启用TLS",
          "description": "启用TLS",
          "markdownDescription": "启用`TLS`"
        },
        "alpn": {
          "$ref": "#/definitions/types/stringArray",
          "title": "ALPN",
          "description": "Application-Layer Protocol Negotiation(应用层协议协商)",
          "markdownDescription": "Application-Layer Protocol Negotiation(应用层协议协商)"
        },
        "skip-cert-verify": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "跳过证书验证",
          "description": "跳过证书验证",
          "markdownDescription": "跳过证书验证"
        },
        "fingerprint": {
          "$ref": "#/definitions/patterns/sha256Fingerprint",
          "title": "SHA-256证书指纹",
          "description": "服务端证书的SHA-256指纹",
          "markdownDescription": "服务端证书的`SHA-256`指纹"
        },
        "certificate": {
          "$ref": "#/definitions/compatible/string",
          "title": "证书或证书路径",
          "description": "PEM格式",
          "markdownDescription": "PEM格式"
        },
        "private-key": {
          "$ref": "#/definitions/compatible/string",
          "title": "私钥",
          "description": "私钥内容或私钥文件路径",
          "markdownDescription": "私钥内容或私钥文件路径"
        },
        "servername": {
          "$ref": "#/definitions/compatible/string",
          "title": "服务器名称",
          "description": "服务器名称",
          "markdownDescription": "服务器名称"
        },
        "ech-opts": { "$ref": "#/definitions/ech-options" },
        "reality-opts": { "$ref": "#/definitions/reality-option" },
        "tlsmirror-opts": { "$ref": "#/definitions/tlsmirror-option" },
        "mkcp-opts": { "$ref": "#/definitions/mkcp-option" },
        "http-opts": { "$ref": "#/definitions/http-option" },
        "h2-opts": { "$ref": "#/definitions/http2-option" },
        "grpc-opts": { "$ref": "#/definitions/grpc-option" },
        "ws-opts": { "$ref": "#/definitions/ws-option" },
        "packet-addr": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "保留原始数据包的地址信息",
          "description": "启用xudp时关闭;packet-encoding取值为packetaddr,packet时启用",
          "markdownDescription": "启用`xudp`时关闭;`packet-encoding`取值为`packetaddr`,`packet`时启用"
        },
        "xudp": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "启用XUDP",
          "description": "启用XUDP(eXtended User Datagram Protocol)",
          "markdownDescription": "启用`XUDP`(eXtended User Datagram Protocol)"
        },
        "packet-encoding": {
          "enum": ["packetaddr", "packet", "xudp"],
          "title": "数据包的编码方式",
          "description": "数据包的编码方式",
          "markdownDescription": "数据包的编码方式"
        },
        "global-padding": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "全局填充",
          "description": "全局填充",
          "markdownDescription": "全局填充"
        },
        "authenticated-length": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "启用验证信息长度",
          "description": "启用验证信息长度",
          "markdownDescription": "启用验证信息长度"
        },
        "client-fingerprint": {
          "$ref": "#/definitions/enums/client-fingerprint",
          "title": "客户端指纹",
          "description": "客户端指纹",
          "markdownDescription": "客户端指纹"
        }
      }
    },
    {
      "type": "object",
      "title": "smux配置",
      "properties": { "smux": { "title": "smux配置", "$ref": "#/definitions/smux" } }
    }
  ]
}
