{
  "type": "object",
  "title": "outbound-vmess",
  "definitions": {
    "compatible": { "$ref": "../../../definitions/compatible.json" },
    "types": { "$ref": "../../../definitions/types.json" },
    "patterns": { "$ref": "../../../definitions/patterns.json" },
    "enums": { "$ref": "../../../definitions/enums.json" },
    "basic-option": { "$ref": "./base.json#/definitions/basic-option" },
    "ech-options": { "$ref": "./ech.json#/definitions/ech-options" },
    "shadow-tls-options": { "$ref": "./shadowtls.json" },
    "restls-options": { "$ref": "./restls.json" },
    "jls-options": { "$ref": "./jls.json" },
    "smux": { "$ref": "./singmux.json" },
    "reality-option": { "$ref": "./reality.json" },
    "tlsmirror-option": { "$ref": "./tlsmirror.json" },
    "mkcp-option": {
      "type": "object",
      "title": "mKCP配置",
      "properties": {
        "mtu": {
          "$ref": "#/definitions/compatible/integer",
          "title": "最大传输单元",
          "description": "最大传输单元，0使用默认值1350",
          "markdownDescription": "最大传输单元，`0`使用默认值`1350`",
          "default": 1350
        },
        "tti": {
          "$ref": "#/definitions/compatible/integer",
          "title": "传输时间间隔",
          "description": "单位:ms，0使用默认值50",
          "markdownDescription": "单位:`ms`，`0`使用默认值`50`",
          "default": 50
        },
        "uplink-capacity": {
          "$ref": "#/definitions/compatible/integer",
          "title": "上行容量",
          "description": "单位:MB/s，0使用默认值5",
          "markdownDescription": "单位:`MB/s`，`0`使用默认值`5`",
          "default": 5
        },
        "downlink-capacity": {
          "$ref": "#/definitions/compatible/integer",
          "title": "下行容量",
          "description": "单位:MB/s，0使用默认值20",
          "markdownDescription": "单位:`MB/s`，`0`使用默认值`20`",
          "default": 20
        },
        "congestion": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "启用拥塞控制",
          "description": "启用拥塞控制",
          "markdownDescription": "启用拥塞控制",
          "default": false
        },
        "write-buffer": {
          "$ref": "#/definitions/compatible/integer",
          "title": "写缓冲区大小",
          "description": "单位:bytes，0使用默认值2097152",
          "markdownDescription": "单位:`bytes`，`0`使用默认值`2097152`",
          "default": 2097152
        },
        "read-buffer": {
          "$ref": "#/definitions/compatible/integer",
          "title": "读缓冲区大小",
          "description": "单位:bytes，0使用默认值2097152",
          "markdownDescription": "单位:`bytes`，`0`使用默认值`2097152`",
          "default": 2097152
        },
        "seed": {
          "$ref": "#/definitions/compatible/string",
          "title": "AES-GCM认证种子",
          "description": "未配置时使用默认认证",
          "markdownDescription": "未配置时使用默认认证"
        },
        "header": {
          "enum": ["none", "noop", "srtp", "utp", "wechat-video", "wechat", "dtls", "wireguard"],
          "markdownEnumDescriptions": [
            "不添加伪装包头",
            "不添加伪装包头",
            "模拟SRTP",
            "模拟uTP",
            "模拟微信视频",
            "模拟微信视频",
            "模拟DTLS",
            "模拟WireGuard"
          ],
          "title": "伪装包头",
          "description": "未配置时不添加伪装包头",
          "markdownDescription": "未配置时不添加伪装包头"
        }
      }
    },
    "mekya-option": {
      "type": "object",
      "title": "Mekya配置",
      "properties": {
        "url": {
          "$ref": "#/definitions/compatible/string",
          "title": "Mekya请求地址",
          "description": "未配置时使用当前VMess服务器地址",
          "markdownDescription": "未配置时使用当前`VMess`服务器地址"
        },
        "h2-pool-size": {
          "$ref": "#/definitions/compatible/integer",
          "title": "HTTP/2连接池大小",
          "description": "HTTP/2连接池大小",
          "markdownDescription": "`HTTP/2`连接池大小"
        },
        "max-write-delay": {
          "$ref": "#/definitions/compatible/integer",
          "title": "首包后的最大聚合等待时间",
          "description": "单位:ms",
          "markdownDescription": "单位:`ms`"
        },
        "max-request-size": {
          "$ref": "#/definitions/compatible/integer",
          "title": "单次HTTP请求的最大负载大小",
          "description": "单位:bytes，0不限制",
          "markdownDescription": "单位:`bytes`，`0`不限制"
        },
        "polling-interval-initial": {
          "$ref": "#/definitions/compatible/integer",
          "title": "初始空轮询间隔",
          "description": "单位:ms",
          "markdownDescription": "单位:`ms`"
        },
        "max-write-size": {
          "$ref": "#/definitions/compatible/integer",
          "title": "单个响应写回的最大负载大小",
          "description": "服务端参数，单位:bytes，0不限制",
          "markdownDescription": "服务端参数，单位:`bytes`，`0`不限制"
        },
        "max-write-duration-ms": {
          "$ref": "#/definitions/compatible/integer",
          "title": "单个响应写回的最大持续时间",
          "description": "服务端参数，单位:ms",
          "markdownDescription": "服务端参数，单位:`ms`"
        },
        "max-simultaneous-write-connection": {
          "$ref": "#/definitions/compatible/integer",
          "title": "同时等待写回的最大请求数",
          "description": "服务端参数，0不限制",
          "markdownDescription": "服务端参数，`0`不限制"
        },
        "packet-writing-buffer": {
          "$ref": "#/definitions/compatible/integer",
          "title": "写包缓冲区大小",
          "description": "服务端写包缓冲区大小",
          "markdownDescription": "服务端写包缓冲区大小"
        },
        "kcp": {
          "$ref": "#/definitions/mkcp-option",
          "title": "mKCP配置",
          "description": "Mekya使用的mKCP配置",
          "markdownDescription": "`Mekya`使用的`mKCP`配置"
        }
      }
    },
    "http-option": {
      "type": "object",
      "title": "HTTP配置",
      "properties": {
        "method": {
          "$ref": "#/definitions/compatible/string",
          "title": "请求方式",
          "description": "请求方式",
          "markdownDescription": "请求方式",
          "default": "GET"
        },
        "path": {
          "$ref": "#/definitions/types/stringArray",
          "title": "路径",
          "description": "路径",
          "markdownDescription": "路径",
          "default": ["/"]
        },
        "headers": {
          "type": "object",
          "title": "请求头",
          "description": "请求头",
          "markdownDescription": "请求头"
        }
      }
    },
    "http2-option": {
      "type": "object",
      "title": "HTTP2配置",
      "properties": {
        "host": {
          "$ref": "#/definitions/types/stringArray",
          "title": "主机地址",
          "description": "主机地址",
          "markdownDescription": "主机地址",
          "default": ["www.example.com"]
        },
        "path": {
          "$ref": "#/definitions/compatible/string",
          "title": "路径",
          "description": "路径",
          "markdownDescription": "路径",
          "default": "/"
        }
      }
    },
    "grpc-option": {
      "type": "object",
      "title": "GRPC配置",
      "properties": {
        "grpc-service-name": {
          "$ref": "#/definitions/compatible/string",
          "title": "GRPC服务名称",
          "description": "GRPC服务名称",
          "markdownDescription": "GRPC服务名称"
        },
        "grpc-user-agent": {
          "$ref": "#/definitions/compatible/string",
          "title": "GRPC用户代理",
          "description": "GRPC用户代理",
          "markdownDescription": "GRPC用户代理"
        },
        "ping-interval": {
          "$ref": "#/definitions/compatible/integer",
          "title": "GRPC心跳间隔",
          "description": "单位:s",
          "markdownDescription": "单位:s"
        },
        "max-connections": {
          "$ref": "#/definitions/compatible/integer",
          "title": "最大连接数",
          "description": "与 max-streams 冲突",
          "markdownDescription": "与 `max-streams` 冲突"
        },
        "min-streams": {
          "$ref": "#/definitions/compatible/integer",
          "title": "每连接最小复用流数",
          "description": "与 max-streams 冲突",
          "markdownDescription": "与 `max-streams` 冲突"
        },
        "max-streams": {
          "$ref": "#/definitions/compatible/integer",
          "title": "每连接最大复用流数",
          "description": "与 max-connections 、 min-streams 冲突",
          "markdownDescription": "与 `max-connections` 、 `min-streams` 冲突"
        }
      },
      "allOf": [
        {
          "if": { "required": ["max-connections", "max-streams"] },
          "then": { "deprecationMessage": "max-connections 与 max-streams 不能同时设置" }
        },
        {
          "if": { "required": ["min-streams", "max-streams"] },
          "then": { "deprecationMessage": "min-streams 与 max-streams 不能同时设置" }
        }
      ]
    },
    "ws-option": {
      "type": "object",
      "title": "WS配置",
      "properties": {
        "path": {
          "$ref": "#/definitions/compatible/string",
          "title": "路径",
          "description": "路径",
          "markdownDescription": "路径",
          "default": "/"
        },
        "headers": {
          "type": "object",
          "title": "请求头",
          "description": "请求头",
          "markdownDescription": "请求头"
        },
        "max-early-data": {
          "$ref": "#/definitions/compatible/integer",
          "title": "最大早期数据大小",
          "description": "单位:bytes",
          "markdownDescription": "单位:`bytes`"
        },
        "early-data-header-name": {
          "$ref": "#/definitions/compatible/string",
          "title": "早期数据使用的header字段名",
          "description": "早期数据使用的header字段名",
          "markdownDescription": "早期数据使用的header字段名"
        },
        "v2ray-http-upgrade": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "启用HTTP协议升级",
          "description": "通过HTTP协议与客户端进行通信,并在需要时升级到更高级的协议",
          "markdownDescription": "通过HTTP协议与客户端进行通信,并在需要时升级到更高级的协议"
        },
        "v2ray-http-upgrade-fast-open": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "启用TFO(TCP Fast Open)",
          "description": "启用TFO(TCP Fast Open)",
          "markdownDescription": "启用`TFO`(TCP Fast Open)"
        }
      }
    },
    "shadow-tls-security-mode": {
      "required": ["shadow-tls-opts"],
      "properties": { "shadow-tls-opts": { "$ref": "./shadowtls.json#/definitions/security-mode" } }
    },
    "restls-security-mode": {
      "required": ["restls-opts"],
      "properties": { "restls-opts": { "$ref": "./restls.json#/definitions/security-mode" } }
    },
    "jls-security-mode": {
      "required": ["jls-opts"],
      "properties": { "jls-opts": { "$ref": "./jls.json#/definitions/security-mode" } }
    },
    "reality-security-mode": { "required": ["reality-opts"] },
    "tlsmirror-security-mode": {
      "required": ["tlsmirror-opts"],
      "properties": { "tlsmirror-opts": { "required": ["primary-key"] } }
    }
  },
  "allOf": [
    { "title": "basic配置", "$ref": "#/definitions/basic-option" },
    {
      "type": "object",
      "title": "vmess配置",
      "required": ["name", "server", "port", "uuid", "alterId", "cipher"],
      "properties": {
        "type": {
          "$ref": "#/definitions/compatible/string",
          "title": "代理节点类型",
          "description": "代理节点类型",
          "markdownDescription": "代理节点类型"
        },
        "name": {
          "$ref": "#/definitions/compatible/string",
          "title": "代理节点名称",
          "description": "代理节点名称",
          "markdownDescription": "代理节点名称"
        },
        "server": {
          "$ref": "#/definitions/patterns/server",
          "title": "代理节点服务器",
          "description": "域名或IP",
          "markdownDescription": "域名或IP"
        },
        "port": {
          "$ref": "#/definitions/patterns/port",
          "title": "代理节点端口号",
          "description": "代理节点端口号",
          "markdownDescription": "代理节点端口号"
        },
        "uuid": {
          "$ref": "#/definitions/patterns/uuid",
          "title": "UUID",
          "description": "UUID",
          "markdownDescription": "UUID"
        },
        "alterId": {
          "$ref": "#/definitions/compatible/integer",
          "title": "AlterID",
          "description": "Alternate ID(替代标识)",
          "markdownDescription": "Alternate ID(替代标识)"
        },
        "cipher": {
          "$ref": "#/definitions/enums/cipher",
          "title": "加密方法",
          "description": "加密方法",
          "markdownDescription": "加密方法"
        },
        "udp": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "启用UDP",
          "description": "启用UDP",
          "markdownDescription": "启用`UDP`"
        },
        "network": {
          "enum": ["tcp", "ws", "http", "h2", "grpc", "mkcp", "kcp", "mekya"],
          "title": "传输协议",
          "description": "传输协议",
          "markdownDescription": "传输协议"
        },
        "tls": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "启用TLS",
          "description": "启用TLS",
          "markdownDescription": "启用`TLS`"
        },
        "alpn": {
          "$ref": "#/definitions/types/stringArray",
          "title": "ALPN",
          "description": "Application-Layer Protocol Negotiation(应用层协议协商)",
          "markdownDescription": "Application-Layer Protocol Negotiation(应用层协议协商)"
        },
        "skip-cert-verify": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "跳过证书验证",
          "description": "跳过证书验证",
          "markdownDescription": "跳过证书验证"
        },
        "name-cert-verify": {
          "$ref": "#/definitions/compatible/string",
          "title": "证书 DNSName 校验目标",
          "description": "仅修改证书 DNSName 校验目标，不修改 SNI",
          "markdownDescription": "仅修改证书 `DNSName` 校验目标，不修改 `SNI`"
        },
        "fingerprint": {
          "$ref": "#/definitions/patterns/sha256Fingerprint",
          "title": "SHA-256证书指纹",
          "description": "服务端证书的SHA-256指纹",
          "markdownDescription": "服务端证书的`SHA-256`指纹"
        },
        "certificate": {
          "$ref": "#/definitions/compatible/string",
          "title": "证书或证书路径",
          "description": "PEM格式",
          "markdownDescription": "PEM格式"
        },
        "private-key": {
          "$ref": "#/definitions/compatible/string",
          "title": "私钥",
          "description": "私钥内容或私钥文件路径",
          "markdownDescription": "私钥内容或私钥文件路径"
        },
        "servername": {
          "$ref": "#/definitions/compatible/string",
          "title": "服务器名称",
          "description": "服务器名称",
          "markdownDescription": "服务器名称"
        },
        "ech-opts": { "$ref": "#/definitions/ech-options" },
        "shadow-tls-opts": { "$ref": "#/definitions/shadow-tls-options" },
        "restls-opts": { "$ref": "#/definitions/restls-options" },
        "jls-opts": { "$ref": "#/definitions/jls-options" },
        "reality-opts": { "$ref": "#/definitions/reality-option" },
        "tlsmirror-opts": { "$ref": "#/definitions/tlsmirror-option" },
        "mekya-opts": { "$ref": "#/definitions/mekya-option" },
        "mkcp-opts": { "$ref": "#/definitions/mkcp-option" },
        "http-opts": { "$ref": "#/definitions/http-option" },
        "h2-opts": { "$ref": "#/definitions/http2-option" },
        "grpc-opts": { "$ref": "#/definitions/grpc-option" },
        "ws-opts": { "$ref": "#/definitions/ws-option" },
        "packet-addr": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "保留原始数据包的地址信息",
          "description": "启用xudp时关闭;packet-encoding取值为packetaddr,packet时启用",
          "markdownDescription": "启用`xudp`时关闭;`packet-encoding`取值为`packetaddr`,`packet`时启用"
        },
        "xudp": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "启用XUDP",
          "description": "启用XUDP(eXtended User Datagram Protocol)",
          "markdownDescription": "启用`XUDP`(eXtended User Datagram Protocol)"
        },
        "packet-encoding": {
          "enum": ["packetaddr", "packet", "xudp"],
          "title": "数据包的编码方式",
          "description": "数据包的编码方式",
          "markdownDescription": "数据包的编码方式"
        },
        "global-padding": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "全局填充",
          "description": "全局填充",
          "markdownDescription": "全局填充"
        },
        "authenticated-length": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "启用验证信息长度",
          "description": "启用验证信息长度",
          "markdownDescription": "启用验证信息长度"
        },
        "client-fingerprint": {
          "$ref": "#/definitions/enums/client-fingerprint",
          "title": "客户端指纹",
          "description": "客户端指纹",
          "markdownDescription": "客户端指纹"
        }
      },
      "allOf": [
        {
          "if": {
            "anyOf": [
              { "$ref": "#/definitions/shadow-tls-security-mode" },
              { "$ref": "#/definitions/restls-security-mode" },
              { "$ref": "#/definitions/jls-security-mode" },
              { "$ref": "#/definitions/reality-security-mode" },
              { "$ref": "#/definitions/tlsmirror-security-mode" }
            ]
          },
          "then": { "required": ["tls"], "properties": { "tls": { "const": true } } }
        },
        {
          "not": {
            "anyOf": [
              {
                "allOf": [
                  { "$ref": "#/definitions/shadow-tls-security-mode" },
                  { "$ref": "#/definitions/restls-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/shadow-tls-security-mode" },
                  { "$ref": "#/definitions/jls-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/shadow-tls-security-mode" },
                  { "$ref": "#/definitions/reality-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/shadow-tls-security-mode" },
                  { "$ref": "#/definitions/tlsmirror-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/restls-security-mode" },
                  { "$ref": "#/definitions/jls-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/restls-security-mode" },
                  { "$ref": "#/definitions/reality-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/restls-security-mode" },
                  { "$ref": "#/definitions/tlsmirror-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/jls-security-mode" },
                  { "$ref": "#/definitions/reality-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/jls-security-mode" },
                  { "$ref": "#/definitions/tlsmirror-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/reality-security-mode" },
                  { "$ref": "#/definitions/tlsmirror-security-mode" }
                ]
              }
            ]
          }
        },
        {
          "if": {
            "anyOf": [
              { "$ref": "#/definitions/shadow-tls-security-mode" },
              { "$ref": "#/definitions/restls-security-mode" },
              { "$ref": "#/definitions/jls-security-mode" }
            ]
          },
          "then": {
            "not": {
              "required": ["network"],
              "properties": { "network": { "enum": ["kcp", "mkcp"] } }
            }
          }
        }
      ]
    },
    {
      "type": "object",
      "title": "smux配置",
      "properties": { "smux": { "title": "smux配置", "$ref": "#/definitions/smux" } }
    }
  ]
}
