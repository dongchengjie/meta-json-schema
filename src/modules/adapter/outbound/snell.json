{
  "type": "object",
  "title": "outbound-snell",
  "definitions": {
    "compatible": { "$ref": "../../../definitions/compatible.json" },
    "types": { "$ref": "../../../definitions/types.json" },
    "patterns": { "$ref": "../../../definitions/patterns.json" },
    "enums": { "$ref": "../../../definitions/enums.json" },
    "basic-option": { "$ref": "./base.json#/definitions/basic-option" },
    "smux": { "$ref": "./singmux.json" },
    "simple-obfs-option": {
      "type": "object",
      "title": "简易混淆配置",
      "properties": {
        "mode": {
          "enum": ["tls", "http"],
          "title": "混淆模式",
          "description": "混淆模式",
          "markdownDescription": "混淆模式"
        },
        "host": {
          "$ref": "#/definitions/patterns/server",
          "title": "主机地址",
          "description": "主机地址",
          "markdownDescription": "主机地址",
          "default": "bing.com"
        }
      }
    },
    "shadow-tls-option": {
      "type": "object",
      "title": "ShadowTLS混淆配置",
      "required": ["mode", "host"],
      "properties": {
        "mode": {
          "const": "shadow-tls",
          "title": "混淆模式",
          "description": "混淆模式",
          "markdownDescription": "混淆模式"
        },
        "password": {
          "$ref": "#/definitions/compatible/string",
          "title": "密码",
          "description": "ShadowTLS v2/v3密码",
          "markdownDescription": "`ShadowTLS` v2/v3密码"
        },
        "host": {
          "$ref": "#/definitions/patterns/server",
          "title": "主机地址",
          "description": "TLS服务器名称",
          "markdownDescription": "`TLS`服务器名称"
        },
        "fingerprint": {
          "$ref": "#/definitions/patterns/sha256Fingerprint",
          "title": "SHA-256证书指纹",
          "description": "服务端证书的SHA-256指纹",
          "markdownDescription": "服务端证书的`SHA-256`指纹"
        },
        "certificate": {
          "$ref": "#/definitions/compatible/string",
          "title": "证书或证书路径",
          "description": "PEM格式",
          "markdownDescription": "PEM格式"
        },
        "private-key": {
          "$ref": "#/definitions/compatible/string",
          "title": "私钥",
          "description": "私钥内容或私钥文件路径",
          "markdownDescription": "私钥内容或私钥文件路径"
        },
        "skip-cert-verify": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "跳过证书验证",
          "description": "跳过证书验证",
          "markdownDescription": "跳过证书验证"
        },
        "name-cert-verify": {
          "$ref": "#/definitions/compatible/string",
          "title": "证书 DNSName 校验目标",
          "description": "仅修改证书 DNSName 校验目标，不修改 SNI",
          "markdownDescription": "仅修改证书 `DNSName` 校验目标，不修改 `SNI`"
        },
        "version": {
          "enum": [1, 2, 3],
          "title": "版本",
          "description": "版本",
          "markdownDescription": "版本",
          "default": 2
        },
        "alpn": {
          "$ref": "#/definitions/types/stringArray",
          "title": "ALPN",
          "description": "Application-Layer Protocol Negotiation(应用层协议协商)",
          "markdownDescription": "Application-Layer Protocol Negotiation(应用层协议协商)",
          "default": ["h2", "http/1.1"]
        }
      }
    },
    "restls-option": {
      "type": "object",
      "title": "Restls混淆配置",
      "required": ["mode", "version-hint"],
      "properties": {
        "mode": {
          "const": "restls",
          "title": "混淆模式",
          "description": "混淆模式",
          "markdownDescription": "混淆模式"
        },
        "password": {
          "$ref": "#/definitions/compatible/string",
          "title": "密码",
          "description": "Restls认证密码",
          "markdownDescription": "`Restls`认证密码"
        },
        "host": {
          "$ref": "#/definitions/patterns/server",
          "title": "主机地址",
          "description": "TLS服务器名称",
          "markdownDescription": "`TLS`服务器名称"
        },
        "version-hint": {
          "enum": ["tls12", "tls13"],
          "markdownEnumDescriptions": ["TLS 1.2", "TLS 1.3"],
          "title": "TLS版本提示",
          "description": "Restls握手使用的TLS版本，应与伪装目标服务器一致",
          "markdownDescription": "`Restls`握手使用的`TLS`版本，应与伪装目标服务器一致"
        },
        "restls-script": {
          "$ref": "#/definitions/compatible/string",
          "title": "Restls脚本",
          "description": "Restls脚本隐藏代理流量行为",
          "markdownDescription": "[Restls脚本隐藏代理流量行为](https://github.com/3andne/restls/blob/main/Restls-Script%3A%20Hide%20Your%20Proxy%20Traffic%20Behavior.md)"
        },
        "fingerprint": {
          "$ref": "#/definitions/patterns/sha256Fingerprint",
          "title": "SHA-256证书指纹",
          "description": "服务端证书的SHA-256指纹",
          "markdownDescription": "服务端证书的`SHA-256`指纹"
        },
        "skip-cert-verify": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "跳过证书验证",
          "description": "跳过证书验证",
          "markdownDescription": "跳过证书验证"
        },
        "name-cert-verify": {
          "$ref": "#/definitions/compatible/string",
          "title": "证书 DNSName 校验目标",
          "description": "仅修改证书 DNSName 校验目标，不修改 SNI",
          "markdownDescription": "仅修改证书 `DNSName` 校验目标，不修改 `SNI`"
        }
      }
    },
    "jls-option": {
      "type": "object",
      "title": "JLS混淆配置",
      "required": ["mode", "host", "username", "password"],
      "properties": {
        "mode": {
          "const": "jls",
          "title": "混淆模式",
          "description": "混淆模式",
          "markdownDescription": "混淆模式"
        },
        "host": {
          "$ref": "#/definitions/patterns/server",
          "title": "主机地址",
          "description": "TLS服务器名称",
          "markdownDescription": "`TLS`服务器名称"
        },
        "username": {
          "$ref": "#/definitions/compatible/string",
          "title": "JLS用户名",
          "description": "JLS认证用户名",
          "markdownDescription": "`JLS`认证用户名"
        },
        "password": {
          "$ref": "#/definitions/compatible/string",
          "title": "JLS密码",
          "description": "JLS认证密码",
          "markdownDescription": "`JLS`认证密码"
        },
        "alpn": {
          "$ref": "#/definitions/types/stringArray",
          "title": "ALPN",
          "description": "Application-Layer Protocol Negotiation(应用层协议协商)",
          "markdownDescription": "Application-Layer Protocol Negotiation(应用层协议协商)"
        }
      }
    }
  },
  "allOf": [
    { "title": "basic配置", "$ref": "#/definitions/basic-option" },
    {
      "type": "object",
      "title": "snell配置",
      "required": ["name", "server", "port"],
      "properties": {
        "type": {
          "$ref": "#/definitions/compatible/string",
          "title": "代理节点类型",
          "description": "代理节点类型",
          "markdownDescription": "代理节点类型"
        },
        "name": {
          "$ref": "#/definitions/compatible/string",
          "title": "代理节点名称",
          "description": "代理节点名称",
          "markdownDescription": "代理节点名称"
        },
        "server": {
          "$ref": "#/definitions/patterns/server",
          "title": "代理节点服务器",
          "description": "域名或IP",
          "markdownDescription": "域名或IP"
        },
        "port": {
          "$ref": "#/definitions/patterns/port",
          "title": "代理节点端口号",
          "description": "代理节点端口号",
          "markdownDescription": "代理节点端口号"
        },
        "psk": {
          "$ref": "#/definitions/compatible/string",
          "title": "预共享密钥",
          "description": "预共享密钥",
          "markdownDescription": "预共享密钥"
        },
        "udp": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "启用UDP",
          "description": "仅v3/4/5支持",
          "markdownDescription": "仅v3/4/5支持"
        },
        "version": {
          "enum": [1, 2, 3, 4, 5],
          "title": "版本",
          "description": "版本",
          "markdownDescription": "版本",
          "default": 1
        },
        "reuse": {
          "$ref": "#/definitions/compatible/boolean",
          "title": "连接复用",
          "description": "仅v4/5支持",
          "markdownDescription": "仅v4/5支持"
        },
        "obfs-opts": {
          "title": "混淆配置",
          "description": "Snell混淆配置",
          "markdownDescription": "`Snell`混淆配置",
          "anyOf": [
            { "$ref": "#/definitions/simple-obfs-option" },
            { "$ref": "#/definitions/shadow-tls-option" },
            { "$ref": "#/definitions/restls-option" },
            { "$ref": "#/definitions/jls-option" }
          ]
        },
        "client-fingerprint": {
          "$ref": "#/definitions/enums/client-fingerprint",
          "title": "客户端指纹",
          "description": "客户端指纹",
          "markdownDescription": "客户端指纹"
        }
      }
    },
    {
      "type": "object",
      "title": "smux配置",
      "properties": { "smux": { "title": "smux配置", "$ref": "#/definitions/smux" } }
    }
  ]
}
