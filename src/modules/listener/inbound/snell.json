{
  "type": "object",
  "title": "inbound-snell",
  "definitions": {
    "types": { "$ref": "../../../definitions/types.json" },
    "patterns": { "$ref": "../../../definitions/patterns.json" },
    "enums": { "$ref": "../../../definitions/enums.json" },
    "base-option": { "$ref": "./base.json" },
    "obfs-opts": {
      "type": "object",
      "title": "混淆配置",
      "properties": {
        "mode": {
          "enums": ["tls", "http"],
          "title": "混淆模式",
          "description": "混淆模式",
          "markdownDescription": "混淆模式"
        },
        "host": {
          "$ref": "#/definitions/patterns/server",
          "title": "主机地址",
          "description": "主机地址",
          "markdownDescription": "主机地址",
          "default": "bing.com"
        }
      }
    }
  },
  "allOf": [
    { "title": "入站基础配置", "$ref": "#/definitions/base-option" },
    {
      "type": "object",
      "title": "snell配置",
      "required": ["psk"],
      "properties": {
        "psk": {
          "type": "string",
          "title": "公钥",
          "description": "公钥",
          "markdownDescription": "公钥"
        },
        "udp": {
          "type": "boolean",
          "title": "启用UDP",
          "description": "启用UDP",
          "markdownDescription": "启用`UDP`",
          "default": true
        },
        "version": {
          "enum": [4, 5],
          "title": "版本",
          "description": "版本",
          "markdownDescription": "版本",
          "default": 4
        },
        "obfs-opts": { "$ref": "#/definitions/obfs-opts" }
      }
    }
  ]
}
