{
  "type": "object",
  "title": "inbound-snell",
  "definitions": {
    "patterns": { "$ref": "../../../definitions/patterns.json" },
    "base-option": { "$ref": "./base.json" },
    "shadow-tls": { "$ref": "./shadowtls.json" },
    "res-tls": { "$ref": "./restls.json" },
    "jls-config": { "$ref": "./jls.json" },
    "obfs-opts": {
      "type": "object",
      "title": "混淆配置",
      "properties": {
        "mode": {
          "enum": ["tls", "http"],
          "title": "混淆模式",
          "description": "混淆模式",
          "markdownDescription": "混淆模式"
        },
        "host": {
          "$ref": "#/definitions/patterns/server",
          "title": "主机地址",
          "description": "主机地址",
          "markdownDescription": "主机地址",
          "default": "bing.com"
        }
      }
    },
    "shadow-tls-security-mode": {
      "required": ["shadow-tls"],
      "properties": {
        "shadow-tls": { "required": ["enable"], "properties": { "enable": { "const": true } } }
      }
    },
    "restls-security-mode": {
      "required": ["res-tls"],
      "properties": {
        "res-tls": { "required": ["enable"], "properties": { "enable": { "const": true } } }
      }
    },
    "jls-security-mode": {
      "required": ["jls-config"],
      "properties": {
        "jls-config": { "required": ["enable"], "properties": { "enable": { "const": true } } }
      }
    }
  },
  "allOf": [
    { "title": "入站基础配置", "$ref": "#/definitions/base-option" },
    {
      "type": "object",
      "title": "snell配置",
      "required": ["psk"],
      "properties": {
        "psk": {
          "type": "string",
          "title": "预共享密钥",
          "description": "预共享密钥",
          "markdownDescription": "预共享密钥"
        },
        "version": {
          "enum": [1, 2, 3, 4, 5],
          "title": "版本",
          "description": "版本",
          "markdownDescription": "版本",
          "default": 4
        },
        "udp": {
          "type": "boolean",
          "title": "启用UDP",
          "description": "启用UDP",
          "markdownDescription": "启用`UDP`"
        },
        "obfs-opts": { "$ref": "#/definitions/obfs-opts" },
        "shadow-tls": { "$ref": "#/definitions/shadow-tls" },
        "res-tls": { "$ref": "#/definitions/res-tls" },
        "jls-config": { "$ref": "#/definitions/jls-config" }
      },
      "allOf": [
        {
          "not": {
            "anyOf": [
              {
                "allOf": [
                  { "$ref": "#/definitions/shadow-tls-security-mode" },
                  { "$ref": "#/definitions/restls-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/shadow-tls-security-mode" },
                  { "$ref": "#/definitions/jls-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/restls-security-mode" },
                  { "$ref": "#/definitions/jls-security-mode" }
                ]
              }
            ]
          }
        }
      ]
    }
  ]
}
