{
  "type": "object",
  "title": "inbound-vmess",
  "definitions": {
    "types": { "$ref": "../../../definitions/types.json" },
    "patterns": { "$ref": "../../../definitions/patterns.json" },
    "enums": { "$ref": "../../../definitions/enums.json" },
    "tls": { "$ref": "../../config/tls.json" },
    "base-option": { "$ref": "./base.json" },
    "mux-option": { "$ref": "./mux.json" },
    "vmess-user": {
      "type": "object",
      "title": "vmess用户",
      "required": ["uuid"],
      "properties": {
        "username": {
          "type": "string",
          "title": "用户名",
          "description": "认证用户名",
          "markdownDescription": "认证用户名"
        },
        "uuid": {
          "$ref": "#/definitions/patterns/uuid",
          "title": "UUID",
          "description": "UUID",
          "markdownDescription": "UUID"
        },
        "alterId": {
          "type": "integer",
          "title": "AlterID",
          "description": "Alternate ID(替代标识)",
          "markdownDescription": "Alternate ID(替代标识)"
        }
      }
    },
    "reality-config": { "$ref": "./reality.json" },
    "tlsmirror-time-spec": {
      "type": "object",
      "title": "TLSMirror 延迟配置",
      "properties": {
        "base-nanoseconds": {
          "type": "integer",
          "title": "固定延迟",
          "description": "单位:ns",
          "markdownDescription": "单位:`ns`",
          "default": 0
        },
        "uniform-random-multiplier-nanoseconds": {
          "type": "integer",
          "title": "随机延迟上限",
          "description": "单位:ns",
          "markdownDescription": "单位:`ns`",
          "default": 0
        }
      }
    },
    "tlsmirror-config": {
      "type": "object",
      "title": "TLSMirror 配置",
      "required": ["primary-key"],
      "properties": {
        "primary-key": {
          "type": "string",
          "title": "TLSMirror 主密钥",
          "description": "标准 Base64 编码的 32 字节主密钥",
          "markdownDescription": "标准 Base64 编码的 32 字节主密钥"
        },
        "dest": {
          "type": "string",
          "title": "回落目标地址",
          "description": "TLS 载体连接的转发目标",
          "markdownDescription": "TLS 载体连接的转发目标"
        },
        "proxy": {
          "type": "string",
          "title": "回落转发代理",
          "description": "回落连接使用的代理",
          "markdownDescription": "回落连接使用的代理"
        },
        "explicit-nonce-ciphersuites": {
          "type": "array",
          "title": "TLS 1.2 显式 nonce 加密套件",
          "description": "TLS 1.2载体使用显式nonce的加密套件",
          "markdownDescription": "`TLS 1.2`载体使用显式`nonce`的加密套件",
          "items": { "type": "integer" }
        },
        "defer-instance-derived-write-time": {
          "$ref": "#/definitions/tlsmirror-time-spec",
          "title": "首次写入延迟",
          "description": "首次写入前的延迟",
          "markdownDescription": "首次写入前的延迟"
        },
        "transport-layer-padding": {
          "type": "object",
          "title": "传输层填充配置",
          "description": "传输层填充配置",
          "markdownDescription": "传输层填充配置",
          "properties": {
            "enabled": {
              "type": "boolean",
              "title": "启用传输层填充",
              "description": "启用传输层填充",
              "markdownDescription": "启用传输层填充",
              "default": false
            }
          }
        },
        "connection-enrolment": {
          "type": "object",
          "title": "TLSMirror 连接登记配置",
          "description": "启用兼容V2Ray的连接登记确认",
          "markdownDescription": "启用兼容`V2Ray`的连接登记确认",
          "properties": {
            "primary-ingress-outbound": {
              "type": "string",
              "title": "主入站控制出站",
              "description": "连接登记使用的主入站控制出站",
              "markdownDescription": "连接登记使用的主入站控制出站"
            },
            "primary-egress-outbound": {
              "type": "string",
              "title": "主出站控制出站",
              "description": "连接登记使用的主出站控制出站",
              "markdownDescription": "连接登记使用的主出站控制出站"
            }
          }
        },
        "sequence-watermarking-enabled": {
          "type": "boolean",
          "title": "启用序列水印",
          "description": "启用序列水印",
          "markdownDescription": "启用序列水印",
          "default": false
        }
      }
    }
  },
  "allOf": [
    { "title": "入站基础配置", "$ref": "#/definitions/base-option" },
    {
      "type": "object",
      "title": "vmess配置",
      "required": ["users"],
      "properties": {
        "users": {
          "type": "array",
          "title": "用户列表",
          "description": "用户列表",
          "markdownDescription": "用户列表",
          "items": { "$ref": "#/definitions/vmess-user" }
        },
        "ws-path": {
          "type": "string",
          "title": "ws路径",
          "description": "ws路径",
          "markdownDescription": "ws路径"
        },
        "grpc-service-name": {
          "type": "string",
          "title": "grpc服务名称",
          "description": "如果不为空则开启 grpc 传输层",
          "markdownDescription": "如果不为空则开启 grpc 传输层",
          "default": "GunService"
        },
        "certificate": { "$ref": "#/definitions/tls/properties/certificate" },
        "private-key": { "$ref": "#/definitions/tls/properties/private-key" },
        "client-auth-type": { "$ref": "#/definitions/tls/properties/client-auth-type" },
        "client-auth-cert": { "$ref": "#/definitions/tls/properties/client-auth-cert" },
        "ech-key": { "$ref": "#/definitions/tls/properties/ech-key" },
        "reality-config": { "title": "reality配置", "$ref": "#/definitions/reality-config" },
        "tlsmirror-config": { "$ref": "#/definitions/tlsmirror-config" },
        "mux-option": { "title": "多路复用配置", "$ref": "#/definitions/mux-option" }
      },
      "dependencies": { "certificate": ["private-key"], "private-key": ["certificate"] }
    }
  ]
}
