{
  "type": "object",
  "title": "inbound-vmess",
  "definitions": {
    "types": { "$ref": "../../../definitions/types.json" },
    "patterns": { "$ref": "../../../definitions/patterns.json" },
    "enums": { "$ref": "../../../definitions/enums.json" },
    "tls": { "$ref": "../../config/tls.json" },
    "base-option": { "$ref": "./base.json" },
    "mux-option": { "$ref": "./mux.json" },
    "shadow-tls": { "$ref": "./shadowtls.json" },
    "vmess-user": {
      "type": "object",
      "title": "vmess用户",
      "required": ["uuid"],
      "properties": {
        "username": {
          "type": "string",
          "title": "用户名",
          "description": "认证用户名",
          "markdownDescription": "认证用户名"
        },
        "uuid": {
          "$ref": "#/definitions/patterns/uuid",
          "title": "UUID",
          "description": "UUID",
          "markdownDescription": "UUID"
        },
        "alterId": {
          "type": "integer",
          "title": "AlterID",
          "description": "Alternate ID(替代标识)",
          "markdownDescription": "Alternate ID(替代标识)"
        }
      }
    },
    "reality-config": { "$ref": "./reality.json" },
    "jls-config": { "$ref": "./jls.json" },
    "tlsmirror-config": { "$ref": "./tlsmirror.json" },
    "mekya-config": { "$ref": "./mekya.json" },
    "mkcp-config": { "$ref": "./mkcp.json" },
    "certificate-security-mode": { "required": ["certificate", "private-key"] },
    "shadow-tls-security-mode": {
      "required": ["shadow-tls"],
      "properties": {
        "shadow-tls": { "required": ["enable"], "properties": { "enable": { "const": true } } }
      }
    },
    "jls-security-mode": {
      "required": ["jls-config"],
      "properties": {
        "jls-config": { "required": ["enable"], "properties": { "enable": { "const": true } } }
      }
    },
    "reality-security-mode": { "required": ["reality-config"] },
    "tlsmirror-security-mode": {
      "required": ["tlsmirror-config"],
      "properties": { "tlsmirror-config": { "required": ["primary-key"] } }
    }
  },
  "allOf": [
    { "title": "入站基础配置", "$ref": "#/definitions/base-option" },
    {
      "type": "object",
      "title": "vmess配置",
      "required": ["users"],
      "properties": {
        "users": {
          "type": "array",
          "title": "用户列表",
          "description": "用户列表",
          "markdownDescription": "用户列表",
          "items": { "$ref": "#/definitions/vmess-user" }
        },
        "ws-path": {
          "type": "string",
          "title": "ws路径",
          "description": "ws路径",
          "markdownDescription": "ws路径"
        },
        "grpc-service-name": {
          "type": "string",
          "title": "grpc服务名称",
          "description": "如果不为空则开启 grpc 传输层",
          "markdownDescription": "如果不为空则开启 grpc 传输层",
          "default": "GunService"
        },
        "certificate": { "$ref": "#/definitions/tls/properties/certificate" },
        "private-key": { "$ref": "#/definitions/tls/properties/private-key" },
        "client-auth-type": { "$ref": "#/definitions/tls/properties/client-auth-type" },
        "client-auth-cert": { "$ref": "#/definitions/tls/properties/client-auth-cert" },
        "ech-key": { "$ref": "#/definitions/tls/properties/ech-key" },
        "shadow-tls": { "$ref": "#/definitions/shadow-tls" },
        "jls-config": { "$ref": "#/definitions/jls-config" },
        "reality-config": { "title": "reality配置", "$ref": "#/definitions/reality-config" },
        "tlsmirror-config": { "$ref": "#/definitions/tlsmirror-config" },
        "mekya-config": { "$ref": "#/definitions/mekya-config" },
        "mkcp-config": { "$ref": "#/definitions/mkcp-config" },
        "mux-option": { "title": "多路复用配置", "$ref": "#/definitions/mux-option" }
      },
      "dependencies": { "certificate": ["private-key"], "private-key": ["certificate"] },
      "allOf": [
        {
          "not": {
            "anyOf": [
              {
                "allOf": [
                  { "$ref": "#/definitions/certificate-security-mode" },
                  { "$ref": "#/definitions/shadow-tls-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/certificate-security-mode" },
                  { "$ref": "#/definitions/jls-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/certificate-security-mode" },
                  { "$ref": "#/definitions/reality-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/certificate-security-mode" },
                  { "$ref": "#/definitions/tlsmirror-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/shadow-tls-security-mode" },
                  { "$ref": "#/definitions/jls-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/shadow-tls-security-mode" },
                  { "$ref": "#/definitions/reality-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/shadow-tls-security-mode" },
                  { "$ref": "#/definitions/tlsmirror-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/jls-security-mode" },
                  { "$ref": "#/definitions/reality-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/jls-security-mode" },
                  { "$ref": "#/definitions/tlsmirror-security-mode" }
                ]
              },
              {
                "allOf": [
                  { "$ref": "#/definitions/reality-security-mode" },
                  { "$ref": "#/definitions/tlsmirror-security-mode" }
                ]
              }
            ]
          }
        },
        {
          "if": {
            "anyOf": [
              { "$ref": "#/definitions/shadow-tls-security-mode" },
              { "$ref": "#/definitions/jls-security-mode" }
            ]
          },
          "then": {
            "not": {
              "required": ["mkcp-config"],
              "properties": {
                "mkcp-config": {
                  "required": ["enable"],
                  "properties": { "enable": { "const": true } }
                }
              }
            }
          }
        },
        {
          "if": {
            "required": ["mekya-config"],
            "properties": {
              "mekya-config": {
                "required": ["enable"],
                "properties": { "enable": { "const": true } }
              }
            }
          },
          "then": {
            "allOf": [
              { "not": { "required": ["ws-path"] } },
              { "not": { "required": ["grpc-service-name"] } },
              {
                "not": {
                  "required": ["mkcp-config"],
                  "properties": {
                    "mkcp-config": {
                      "required": ["enable"],
                      "properties": { "enable": { "const": true } }
                    }
                  }
                }
              }
            ]
          }
        }
      ]
    }
  ]
}
